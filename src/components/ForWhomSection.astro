---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const profiles = [
  {
    icon: '◎',
    title: 'Has probado dietas sin resultados duraderos',
    body: 'Sabes lo que "hay que hacer" pero no consigues mantenerlo. El problema no eres tú: es que el enfoque no tenía en cuenta todo lo que influye.',
  },
  {
    icon: '◎',
    title: 'Tu relación con la comida es complicada',
    body: 'Comes por ansiedad, por aburrimiento o por culpa. O sigues reglas tan estrictas que cualquier desvío lo sientes como un fracaso.',
  },
  {
    icon: '◎',
    title: 'Quieres moverte mejor, no machacarte',
    body: 'No buscas un cuerpo de portada. Buscas energía, menos dolor, más movilidad y sentirte bien en tu cuerpo en el día a día.',
  },
  {
    icon: '◎',
    title: 'Buscas un cambio real, no una solución rápida',
    body: 'Ya no te interesan los atajos. Quieres construir hábitos que funcionen a largo plazo, con acompañamiento profesional de verdad.',
  },
];
---

<section
  style="
    padding: var(--nt-space-3xl) var(--nt-space-md);
    background: var(--nt-bg-muted);
  "
  aria-labelledby="forwhom-heading"
>
  <div style="max-width: var(--nt-container); margin: 0 auto">

    <div class="forwhom-grid">

      <!-- Columna izquierda: encabezado sticky -->
      <div class="forwhom-header">
        <p
          style="
            font-family: var(--nt-font-ui);
            font-size: 0.75rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            color: var(--nt-highlight);
            margin-bottom: var(--nt-space-sm);
          "
        >
          ¿Esto es para ti?
        </p>
        <h2
          id="forwhom-heading"
          style="
            font-family: var(--nt-font-display);
            font-size: clamp(1.75rem, 3vw, 2.5rem);
            font-weight: 700;
            line-height: 1.15;
            letter-spacing: -0.02em;
            color: var(--nt-color-green-900);
            margin-bottom: var(--nt-space-lg);
          "
        >
          Trabajamos con personas que quieren cambiar de verdad
        </h2>
        <p
          style="
            font-family: var(--nt-font-body);
            font-size: 1rem;
            line-height: 1.75;
            color: var(--nt-text-muted);
            margin-bottom: var(--nt-space-xl);
          "
        >
          No importa tu punto de partida. Importa que estés dispuesto a trabajarlo con honestidad y con tiempo.
        </p>
        <a
          href={`${base}/contacto`}
          style="
            display: inline-flex;
            align-items: center;
            background: var(--nt-color-green-800);
            color: var(--nt-color-stone-50);
            font-family: var(--nt-font-ui);
            font-weight: 500;
            padding: 0.75rem 1.75rem;
            border-radius: 3px;
            text-decoration: none;
            font-size: 0.9375rem;
          "
        >
          Pedir primera consulta gratuita
        </a>

        <!-- Imagen lifestyle target — visible solo en desktop donde la col es sticky -->
        <div
          class="forwhom-image"
          style="
            margin-top: var(--nt-space-xl);
            border-radius: 4px;
            overflow: hidden;
            border: 1px solid var(--nt-border);
          "
          aria-hidden="true"
        >
          <!-- Placeholder: foto de persona activa en torno a 50 años
               Sugerencia: exterior natural asturiano, actividad tranquila (senderismo, bicicleta, yoga al aire libre)
               Archivo destino: public/images/lifestyle-madurez-activa.webp
               Proporción ideal: 4:3 horizontal -->
          <div
            style="
              aspect-ratio: 4/3;
              background: var(--nt-color-earth-100);
              display: flex;
              flex-direction: column;
              align-items: center;
              justify-content: center;
              gap: 0.75rem;
              padding: 1.5rem;
              text-align: center;
            "
          >
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" style="color: var(--nt-color-earth-400)">
              <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
              <circle cx="12" cy="13" r="4"/>
            </svg>
            <p style="font-family: var(--nt-font-ui); font-size: 0.75rem; color: var(--nt-color-earth-600); font-weight: 500">
              Persona activa · 50+ años
            </p>
            <p style="font-family: var(--nt-font-ui); font-size: 0.6875rem; color: var(--nt-text-muted); line-height: 1.5; max-width: 14rem">
              Exterior natural asturiano · Actividad tranquila · Luz natural
            </p>
            <p style="font-family: var(--nt-font-ui); font-size: 0.625rem; color: var(--nt-color-stone-300); text-transform: uppercase; letter-spacing: 0.08em">
              lifestyle-madurez-activa.webp
            </p>
          </div>
        </div>
      </div>

      <!-- Columna derecha: perfiles -->
      <div style="display: flex; flex-direction: column; gap: var(--nt-space-md)">
        {profiles.map(({ icon, title, body }) => (
          <div
            style="
              background: var(--nt-bg);
              border: 1px solid var(--nt-border);
              border-radius: 4px;
              padding: var(--nt-space-lg);
              display: flex;
              gap: var(--nt-space-md);
              align-items: flex-start;
            "
          >
            <span
              aria-hidden="true"
              style="
                font-size: 1.25rem;
                color: var(--nt-color-green-500);
                flex-shrink: 0;
                margin-top: 2px;
              "
            >
              {icon}
            </span>
            <div>
              <h3
                style="
                  font-family: var(--nt-font-display);
                  font-size: 1.125rem;
                  font-weight: 700;
                  color: var(--nt-color-green-900);
                  margin-bottom: var(--nt-space-xs);
                  line-height: 1.3;
                "
              >
                {title}
              </h3>
              <p
                style="
                  font-family: var(--nt-font-body);
                  font-size: 0.9375rem;
                  line-height: 1.7;
                  color: var(--nt-text-muted);
                "
              >
                {body}
              </p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .forwhom-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--nt-space-2xl);
  }

  .forwhom-image {
    display: none;
  }

  @media (min-width: 900px) {
    .forwhom-grid {
      grid-template-columns: 2fr 3fr;
      align-items: start;
    }

    .forwhom-header {
      position: sticky;
      top: 6rem;
    }

    .forwhom-image {
      display: block;
    }
  }
</style>
