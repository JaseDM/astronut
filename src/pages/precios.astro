---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaFinal from '../components/CtaFinal.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://jasedm.github.io/astronut';

// ─── DATOS DE PLANES ────────────────────────────────────────────────────────
interface PlanFeature { label: string; value: string }
interface Plan {
  id: string
  eyebrow: string
  name: string
  price: number
  unit: string
  forWhom: string
  features: PlanFeature[]
  cta: string
  highlighted: boolean
  // Imagen placeholder sobre cada tarjeta de plan
  // Proporción ideal: 16:9 — foto de estilo de vida que represente el perfil del plan
  imgDesc: string
  imgFile: string
}

const plans: Plan[] = [
  {
    id: 'esencial',
    eyebrow: 'Para empezar',
    name: 'Esencial',
    price: 79,
    unit: 'mes',
    forWhom: 'Personas que quieren empezar con una base sólida y un ritmo de dos días de entrenamiento semanal.',
    features: [
      { label: 'Consulta base inicial con José Miguel',        value: 'incluida' },
      { label: 'Plan nutricional personalizado de inicio',     value: 'incluido' },
      { label: 'Entrenamiento funcional grupal',               value: '2 días/sem' },
      { label: 'Tamaño de grupo',                              value: 'máx. 10 personas' },
      { label: 'Seguimiento de nutrición al mes',              value: '1 consulta' },
      { label: 'Seguimiento de enfermería al mes',             value: '1 consulta' },
      { label: 'Talleres Nutroteca Academy',                   value: '—' },
      { label: 'Entrenamiento personal',                       value: '—' },
      { label: 'Plataforma Nutroteca',                         value: 'incluida' },
      { label: 'VCI (valoración clínica de enfermería)',       value: 'opcional +59/129€' },
    ],
    cta: 'Empezar con Esencial',
    highlighted: false,
    imgDesc: 'Persona adulta (45-55 años) en primer día de entrenamiento grupal. Expresión de determinación tranquila. Exterior o espacio amplio.',
    imgFile: 'plan-esencial.webp',
  },
  {
    id: 'integral',
    eyebrow: 'El más completo',
    name: 'Integral',
    price: 129,
    unit: 'mes',
    forWhom: 'Personas que buscan mayor intensidad de acompañamiento y valoran el componente formativo y comunitario.',
    features: [
      { label: 'Consulta base inicial con José Miguel',        value: 'incluida' },
      { label: 'Plan nutricional personalizado de inicio',     value: 'incluido' },
      { label: 'Entrenamiento funcional grupal',               value: '3 días/sem' },
      { label: 'Tamaño de grupo',                              value: 'máx. 10 personas' },
      { label: 'Seguimiento de nutrición al mes',              value: '2 consultas' },
      { label: 'Seguimiento de enfermería al mes',             value: '1 consulta' },
      { label: 'Talleres Nutroteca Academy',                   value: '1/mes' },
      { label: 'Entrenamiento personal',                       value: '—' },
      { label: 'Plataforma Nutroteca',                         value: 'incluida' },
      { label: 'VCI (valoración clínica de enfermería)',       value: 'opcional +59/129€' },
    ],
    cta: 'Empezar con Integral',
    highlighted: true,
    imgDesc: 'Grupo pequeño (3-5 personas, adultos 45-65 años) en actividad de entrenamiento funcional, ambiente cálido y colaborativo.',
    imgFile: 'plan-integral.webp',
  },
  {
    id: 'premium',
    eyebrow: 'Máximo acompañamiento',
    name: 'Premium',
    price: 189,
    unit: 'mes',
    forWhom: 'Personas que quieren el máximo nivel de personalización y acompañamiento desde el primer día.',
    features: [
      { label: 'Consulta base inicial con José Miguel',        value: 'incluida' },
      { label: 'Plan nutricional con revisión continua',       value: 'incluido' },
      { label: 'Entrenamiento funcional grupal',               value: 'ilimitado (máx. 1/día)' },
      { label: 'Tamaño de grupo',                              value: 'máx. 10 personas' },
      { label: 'Seguimiento de nutrición al mes',              value: '2 consultas' },
      { label: 'Seguimiento de enfermería al mes',             value: '1 consulta' },
      { label: 'Talleres Nutroteca Academy',                   value: 'todos incluidos' },
      { label: 'Entrenamiento personal',                       value: '1 sesión/semana' },
      { label: 'Plataforma Nutroteca',                         value: 'acceso prioritario' },
      { label: 'VCI Completa (con médico del deporte)',        value: '1/año incluida' },
    ],
    cta: 'Empezar con Premium',
    highlighted: false,
    imgDesc: 'Persona activa (~55 años) en sesión de entrenamiento personal, movimiento preciso y confiado. Luz natural, espacio profesional.',
    imgFile: 'plan-premium.webp',
  },
];

// ─── TABLA COMPARATIVA ──────────────────────────────────────────────────────
interface CompRow { feature: string; esencial: string; integral: string; premium: string }
const compRows: CompRow[] = [
  { feature: 'Consulta base inicial',          esencial: '✓',            integral: '✓',              premium: '✓' },
  { feature: 'VCI incluida',                   esencial: '—',            integral: '—',              premium: '1/año' },
  { feature: 'Entrenamiento grupal',           esencial: '2 días/sem',   integral: '3 días/sem',     premium: 'ilimitado' },
  { feature: 'Entrenamiento personal',         esencial: '—',            integral: '—',              premium: '1/semana' },
  { feature: 'Seguimiento nutrición/mes',      esencial: '1 consulta',   integral: '2 consultas',    premium: '2 consultas' },
  { feature: 'Seguimiento enfermería/mes',     esencial: '1 consulta',   integral: '1 consulta',     premium: '1 consulta' },
  { feature: 'Talleres Academy',               esencial: '—',            integral: '1/mes',          premium: 'todos' },
  { feature: 'Plataforma Nutroteca',           esencial: '✓',            integral: '✓',              premium: 'prioritario' },
  { feature: 'Sin permanencia',                esencial: '✓',            integral: '✓',              premium: '✓' },
  { feature: 'Sin matrícula',                  esencial: '✓',            integral: '✓',              premium: '✓' },
];

// ─── SCHEMA ─────────────────────────────────────────────────────────────────
const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Nutroteca', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Planes y precios', item: `${siteUrl}/precios` },
  ],
};

const schemaOffers = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Planes Nutroteca',
  itemListElement: plans.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Offer',
      name: `Nutroteca ${p.name}`,
      description: p.forWhom,
      price: p.price,
      priceCurrency: 'EUR',
      priceSpecification: { '@type': 'UnitPriceSpecification', price: p.price, priceCurrency: 'EUR', unitText: 'MONTH' },
    },
  })),
};

// Helper: color de celda en tabla comparativa
function cellColor(val: string): string {
  if (val === '✓' || val === 'todos' || val === 'ilimitado' || val === 'prioritario') return 'var(--nt-color-green-600)';
  if (val === '—') return 'var(--nt-color-stone-400)';
  return 'var(--nt-color-green-900)';
}
---

<BaseLayout
  title="Planes y precios — Nutroteca | Sin matrícula ni permanencia"
  description="Descubre los planes de Nutroteca: Esencial (79€/mes), Integral (129€/mes) y Premium (189€/mes). Sin matrícula, sin permanencia. Primera consulta gratuita."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaOffers)} slot="head" />

  <SiteNav />

  <main>

    <!-- ─── HERO ─────────────────────────────────────────── -->
    <section
      class="nt-grain nt-grain-dark nt-hex-pattern"
      style="background: var(--nt-gradient-dark); padding: calc(var(--nt-space-3xl) + 4rem) var(--nt-space-md) var(--nt-space-3xl);"
    >
      <div style="max-width: var(--nt-container); margin: 0 auto; position: relative; z-index: 2;">

        <nav aria-label="Ruta de navegación" style="margin-bottom: var(--nt-space-lg)">
          <ol style="display:flex; gap:.5rem; align-items:center; list-style:none; padding:0; margin:0; font-family:var(--nt-font-ui); font-size:.8125rem; color:var(--nt-color-green-400)">
            <li><a href={`${base}/`} style="color:var(--nt-color-green-400); text-decoration:none">Inicio</a></li>
            <li aria-hidden="true" style="opacity:.4">·</li>
            <li style="color:var(--nt-color-stone-300)">Planes y precios</li>
          </ol>
        </nav>

        <div class="hero-pricing-grid">
          <div>
            <p style="font-family:var(--nt-font-ui); font-size:.75rem; font-weight:500; text-transform:uppercase; letter-spacing:.14em; color:var(--nt-color-earth-400); margin-bottom:var(--nt-space-md)">
              Planes y precios
            </p>
            <h1 style="font-family:var(--nt-font-display); font-size:clamp(2.25rem,5vw,4rem); font-weight:800; line-height:1.1; letter-spacing:-.025em; color:var(--nt-color-stone-50); margin-bottom:var(--nt-space-lg)">
              Sin matrícula.<br />
              <em style="font-style:italic; color:var(--nt-color-earth-400)">Sin permanencia.</em>
            </h1>
            <p style="font-family:var(--nt-font-body); font-size:clamp(1rem,1.75vw,1.1875rem); line-height:1.75; color:var(--nt-color-stone-300); max-width:38rem; margin-bottom:var(--nt-space-xl)">
              El precio mensual es el precio mensual. Puedes empezar, cambiar de plan o dejarlo cuando quieras — sin penalizaciones, sin letra pequeña.
            </p>
            <div style="display:flex; flex-wrap:wrap; gap:var(--nt-space-md)">
              <a href={`${base}/contacto`} style="display:inline-flex; align-items:center; background:var(--nt-color-stone-50); color:var(--nt-color-green-900); font-family:var(--nt-font-ui); font-weight:600; font-size:.9375rem; padding:.875rem 2rem; border-radius:3px; text-decoration:none">
                Primera consulta gratuita
              </a>
              <a href="#planes" style="display:inline-flex; align-items:center; gap:.375rem; color:var(--nt-color-stone-300); font-family:var(--nt-font-ui); font-weight:500; font-size:.9375rem; text-decoration:none">
                Ver planes →
              </a>
            </div>
          </div>

          <!-- Placeholder imagen hero precios -->
          <div aria-hidden="true" class="hero-pricing-img">
            <div style="border-radius:4px; overflow:hidden; border:1px solid rgba(255,255,255,.10)">
              <div style="aspect-ratio:4/3; background:rgba(255,255,255,.04); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem; padding:2rem; text-align:center; position:relative">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" style="color:rgba(255,255,255,.2)"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                <div>
                  <p style="font-family:var(--nt-font-ui); font-size:.8125rem; font-weight:500; color:rgba(255,255,255,.35); margin-bottom:.375rem">Espacio Nutroteca</p>
                  <p style="font-family:var(--nt-font-ui); font-size:.6875rem; color:rgba(255,255,255,.2); max-width:18rem">Sala de consulta y entrenamiento. Luz natural, ambiente cálido y profesional. Transmite confianza sin frialdad clínica.</p>
                  <p style="font-family:var(--nt-font-ui); font-size:.625rem; text-transform:uppercase; letter-spacing:.08em; color:rgba(255,255,255,.15); margin-top:.5rem">espacio-nutroteca.webp</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Garantías rápidas -->
        <div style="margin-top:var(--nt-space-2xl); padding-top:var(--nt-space-lg); border-top:1px solid rgba(255,255,255,.08); display:flex; flex-wrap:wrap; gap:var(--nt-space-xl)">
          {[
            { icon: '○', label: 'Sin matrícula' },
            { icon: '○', label: 'Sin permanencia' },
            { icon: '○', label: 'Cambio de plan en cualquier momento' },
            { icon: '○', label: 'Primera consulta gratuita' },
          ].map(({ icon, label }) => (
            <div style="display:flex; align-items:center; gap:.625rem">
              <span style="color:var(--nt-color-green-400); font-size:.875rem">{icon}</span>
              <p style="font-family:var(--nt-font-ui); font-size:.875rem; color:var(--nt-color-stone-300)">{label}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ─── ACCESO GRATUITO ───────────────────────────────── -->
    <section style="padding:var(--nt-space-3xl) var(--nt-space-md); background:var(--nt-color-earth-100); border-bottom:1px solid var(--nt-border)">
      <div style="max-width:var(--nt-container); margin:0 auto">
        <div style="text-align:center; max-width:34rem; margin:0 auto var(--nt-space-2xl)">
          <p style="font-family:var(--nt-font-ui); font-size:.75rem; font-weight:500; text-transform:uppercase; letter-spacing:.14em; color:var(--nt-color-earth-600); margin-bottom:var(--nt-space-sm)">
            Antes de decidir
          </p>
          <h2 style="font-family:var(--nt-font-display); font-size:clamp(1.75rem,3vw,2.5rem); font-weight:700; letter-spacing:-.02em; color:var(--nt-color-green-900); margin-bottom:var(--nt-space-md)">
            Prueba antes de comprometerte
          </h2>
          <p style="font-family:var(--nt-font-body); font-size:1rem; line-height:1.75; color:var(--nt-text-muted)">
            Dos formas de conocer Nutroteca sin coste y sin compromiso. Sin presión, sin formularios interminables.
          </p>
        </div>

        <div class="free-grid">

          <!-- Toma de contacto -->
          <article style="background:var(--nt-bg); border:1px solid var(--nt-border); border-radius:4px; overflow:hidden">
            <!-- Placeholder imagen -->
            <div style="aspect-ratio:4/3; background:var(--nt-color-stone-100); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:.75rem; padding:1.5rem; text-align:center; border-bottom:1px solid var(--nt-border)" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" style="color:var(--nt-color-stone-300)"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <div>
                <p style="font-family:var(--nt-font-ui); font-size:.75rem; font-weight:500; color:var(--nt-color-stone-400); margin-bottom:.25rem">Conversación inicial</p>
                <p style="font-family:var(--nt-font-ui); font-size:.6875rem; color:var(--nt-text-muted); max-width:14rem; line-height:1.5">José Miguel o Erika frente a una persona. Ambiente cálido, escucha activa. Mesa de madera, luz natural.</p>
                <p style="font-family:var(--nt-font-ui); font-size:.625rem; text-transform:uppercase; letter-spacing:.08em; color:var(--nt-color-stone-300); margin-top:.5rem">contacto-inicial.webp</p>
              </div>
            </div>
            <div style="padding:var(--nt-space-lg)">
              <span style="display:inline-block; background:var(--nt-color-green-100); color:var(--nt-color-green-700); font-family:var(--nt-font-ui); font-size:.75rem; font-weight:600; padding:.2rem .875rem; border-radius:99px; margin-bottom:var(--nt-space-md)">Gratis</span>
              <h3 style="font-family:var(--nt-font-display); font-size:1.5rem; font-weight:700; color:var(--nt-color-green-900); margin-bottom:var(--nt-space-sm)">Toma de contacto inicial</h3>
              <p style="font-family:var(--nt-font-body); font-size:.9375rem; line-height:1.7; color:var(--nt-text-muted); margin-bottom:var(--nt-space-md)">
                Una conversación para conocer el método, los planes, el equipo y el espacio. Previo a la cita te pedimos un pequeño formulario (objetivos, motivación) para que la conversación sea útil desde el primer minuto.
              </p>
              <a href={`${base}/contacto`} style="display:inline-flex; align-items:center; background:var(--nt-color-green-800); color:var(--nt-color-stone-50); font-family:var(--nt-font-ui); font-weight:500; font-size:.9375rem; padding:.75rem 1.75rem; border-radius:3px; text-decoration:none">
                Reservar cita gratuita
              </a>
            </div>
          </article>

          <!-- Clase de prueba -->
          <article style="background:var(--nt-bg); border:1px solid var(--nt-border); border-radius:4px; overflow:hidden">
            <div style="aspect-ratio:4/3; background:var(--nt-color-stone-100); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:.75rem; padding:1.5rem; text-align:center; border-bottom:1px solid var(--nt-border)" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" style="color:var(--nt-color-stone-300)"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <div>
                <p style="font-family:var(--nt-font-ui); font-size:.75rem; font-weight:500; color:var(--nt-color-stone-400); margin-bottom:.25rem">Clase grupal de prueba</p>
                <p style="font-family:var(--nt-font-ui); font-size:.6875rem; color:var(--nt-text-muted); max-width:14rem; line-height:1.5">Grupo de ~8 personas (adultos 45-65 años) en entrenamiento funcional. Movimiento, energía y buen ambiente. Espacio amplio.</p>
                <p style="font-family:var(--nt-font-ui); font-size:.625rem; text-transform:uppercase; letter-spacing:.08em; color:var(--nt-color-stone-300); margin-top:.5rem">clase-prueba-grupal.webp</p>
              </div>
            </div>
            <div style="padding:var(--nt-space-lg)">
              <span style="display:inline-block; background:var(--nt-color-green-100); color:var(--nt-color-green-700); font-family:var(--nt-font-ui); font-size:.75rem; font-weight:600; padding:.2rem .875rem; border-radius:99px; margin-bottom:var(--nt-space-md)">Gratis</span>
              <h3 style="font-family:var(--nt-font-display); font-size:1.5rem; font-weight:700; color:var(--nt-color-green-900); margin-bottom:var(--nt-space-sm)">Clase de entrenamiento de prueba</h3>
              <p style="font-family:var(--nt-font-body); font-size:.9375rem; line-height:1.7; color:var(--nt-text-muted); margin-bottom:var(--nt-space-md)">
                Cualquier clase de las programadas durante la semana, sujeta a aforo disponible (grupos de máximo 10 personas). Para probar el espacio, el estilo y el equipo antes de decidir. Sin compromiso.
              </p>
              <a href={`${base}/contacto`} style="display:inline-flex; align-items:center; background:var(--nt-color-green-800); color:var(--nt-color-stone-50); font-family:var(--nt-font-ui); font-weight:500; font-size:.9375rem; padding:.75rem 1.75rem; border-radius:3px; text-decoration:none">
                Reservar clase gratuita
              </a>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ─── LOS PLANES ───────────────────────────────────── -->
    <section id="planes" style="padding:var(--nt-space-3xl) var(--nt-space-md); background:var(--nt-bg)">
      <div style="max-width:var(--nt-container); margin:0 auto">

        <div style="text-align:center; max-width:36rem; margin:0 auto var(--nt-space-2xl)">
          <p style="font-family:var(--nt-font-ui); font-size:.75rem; font-weight:500; text-transform:uppercase; letter-spacing:.14em; color:var(--nt-highlight); margin-bottom:var(--nt-space-sm)">
            Suscripciones mensuales
          </p>
          <h2 style="font-family:var(--nt-font-display); font-size:clamp(1.75rem,3vw,2.5rem); font-weight:700; letter-spacing:-.02em; color:var(--nt-color-green-900); margin-bottom:var(--nt-space-md)">
            Elige tu nivel de acompañamiento
          </h2>
          <p style="font-family:var(--nt-font-body); font-size:1rem; line-height:1.75; color:var(--nt-text-muted)">
            Todos los planes incluyen la consulta base inicial con José Miguel. Ninguno tiene matrícula ni permanencia.
          </p>
        </div>

        <div class="plans-grid">
          {plans.map((plan) => (
            <article style={`
              background: ${plan.highlighted ? 'var(--nt-color-green-900)' : 'var(--nt-bg)'};
              border: ${plan.highlighted ? '2px solid var(--nt-color-green-600)' : '1px solid var(--nt-border)'};
              border-radius: 4px;
              overflow: hidden;
              display: flex;
              flex-direction: column;
              position: relative;
            `}>

              <!-- Badge "Más popular" -->
              {plan.highlighted && (
                <div style="position:absolute; top:1rem; right:1rem; background:var(--nt-color-earth-500); color:white; font-family:var(--nt-font-ui); font-size:.6875rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em; padding:.25rem .75rem; border-radius:99px">
                  Más popular
                </div>
              )}

              <!-- Imagen placeholder -->
              <div style={`aspect-ratio:16/9; background:${plan.highlighted ? 'rgba(255,255,255,.06)' : 'var(--nt-color-stone-100)'}; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:.75rem; padding:1.25rem; text-align:center; border-bottom:1px solid ${plan.highlighted ? 'rgba(255,255,255,.08)' : 'var(--nt-border)'}`} aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" style={`color:${plan.highlighted ? 'rgba(255,255,255,.2)' : 'var(--nt-color-stone-300)'}`}><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                <p style={`font-family:var(--nt-font-ui); font-size:.6875rem; line-height:1.5; max-width:16rem; color:${plan.highlighted ? 'rgba(255,255,255,.25)' : 'var(--nt-text-muted)'}`}>{plan.imgDesc}</p>
                <p style={`font-family:var(--nt-font-ui); font-size:.625rem; text-transform:uppercase; letter-spacing:.08em; color:${plan.highlighted ? 'rgba(255,255,255,.15)' : 'var(--nt-color-stone-300)'}`}>{plan.imgFile}</p>
              </div>

              <!-- Contenido -->
              <div style="padding:var(--nt-space-lg); display:flex; flex-direction:column; flex:1; gap:var(--nt-space-md)">

                <!-- Eyebrow + nombre -->
                <div>
