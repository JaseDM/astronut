---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nutroteca"
  description="Consulta de salud integral en Asturias: nutrición clínica, entrenamiento funcional y salud emocional. Un sistema coordinado, no tres servicios separados."
>
  <main>
    <!-- En construcción -->
    <div class="min-h-screen flex items-center justify-center px-6">
      <div class="text-center" style="max-width: 36rem">
        <p class="text-sm font-medium uppercase tracking-widest mb-4" style="font-family: var(--nt-font-ui); color: var(--nt-text-muted)">Próximamente</p>
        <h1 class="text-4xl md:text-5xl mb-6">Nutroteca</h1>
        <p class="text-lg" style="color: var(--nt-text-muted)">
          Consulta de salud integral en Asturias.<br />
          Nutrición clínica, entrenamiento funcional y salud emocional.
        </p>
      </div>
    </div>
  </main>
</BaseLayout>
